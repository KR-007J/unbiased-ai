            "description": "Text rewritten successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RewriteResponse"
                }
              }
            }
          }
        }
      }
    },
    "/compare": {
      "post": {
        "tags": ["Analysis"],
        "summary": "Compare two texts for bias",
        "description": "Compare two pieces of content to determine which is more objective and identify specific bias differences.",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompareRequest"
