    "/chat/history": {
      "get": {
        "tags": ["Chat"],
        "summary": "Get conversation history",
        "description": "Retrieve the message history for a specific conversation.",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "conversationId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 50, "maximum": 100 }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Conversation history retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationHistoryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chat/conversations": {
      "get": {
        "tags": ["Chat"],
        "summary": "List user conversations",
