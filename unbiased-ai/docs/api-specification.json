{
  "openapi": "3.0.3",
  "info": {
    "title": "Unbiased AI API",
    "description": "Enterprise-grade API for bias detection, analysis, and governance",
    "version": "1.0.0",
    "contact": {
      "name": "Unbiased AI Support",
      "email": "support@unbiased-ai.dev",
      "url": "https://unbiased-ai.dev"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0"
    }
  },
  "servers": [
    {
      "url": "https://api.unbiased-ai.dev/v1",
      "description": "Production server"
    },
    {
      "url": "https://staging-api.unbiased-ai.dev/v1",
      "description": "Staging server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Analysis",
      "description": "Text and content bias analysis operations"
    },
    {
      "name": "Chat",
      "description": "AI-powered conversational assistance"
    },
    {
      "name": "Organizations",
      "description": "Multi-tenant organization management"
    },
    {
      "name": "Batch Processing",
      "description": "Large-scale batch analysis operations"
    },
    {
      "name": "GDPR Compliance",
      "description": "Data protection and privacy operations"
    },
    {
      "name": "Monitoring",
      "description": "System monitoring and analytics"
    },
    {
      "name": "Scaling",
      "description": "Load balancing and auto-scaling"
    }
  ],
  "paths": {
    "/detect-bias": {
      "post": {
        "tags": ["Analysis"],
        "summary": "Detect bias in text content",
        "description": "Analyze text for various types of bias including gender, racial, political, age, cultural, and socioeconomic bias.",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BiasDetectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bias analysis completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BiasDetectionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RateLimitError"
                }
              }
            }
          }
        },
        "x-code-samples": [
          {
            "lang": "javascript",
            "source": "const response = await fetch('/api/detect-bias', {\n  method: 'POST',\n  headers: {\n    'Content-Type': 'application/json',\n    'Authorization': 'Bearer YOUR_TOKEN'\n  },\n  body: JSON.stringify({\n    content: 'He is a doctor and she is a nurse',\n    type: 'text'\n  })\n});\n\nconst result = await response.json();"
          },
          {
            "lang": "python",
            "source": "import requests\n\nresponse = requests.post('/api/detect-bias',\n  json={\n    'content': 'He is a doctor and she is a nurse',\n    'type': 'text'\n  },\n  headers={'Authorization': 'Bearer YOUR_TOKEN'}\n)\n\nresult = response.json()"
          }
        ]
      }
    },
    "/rewrite": {
      "post": {
        "tags": ["Analysis"],
        "summary": "Rewrite text to remove bias",
        "description": "Generate unbiased alternatives to biased text while preserving meaning and tone.",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RewriteRequest"
              }
