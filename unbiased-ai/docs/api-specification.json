            "description": "Text comparison completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompareResponse"
                }
              }
            }
          }
        }
      }
    },
    "/analyze": {
      "post": {
        "tags": ["Analysis"],
        "summary": "Comprehensive content analysis",
        "description": "Perform deep analysis of text or web content with detailed bias breakdown and recommendations.",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
