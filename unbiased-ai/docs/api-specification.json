                }
              }
            }
          }
        }
      }
    },
    "/chat/send": {
      "post": {
        "tags": ["Chat"],
        "summary": "Send message to AI assistant",
        "description": "Send a message to the AI assistant and receive a response focused on bias awareness and ethical communication.",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
