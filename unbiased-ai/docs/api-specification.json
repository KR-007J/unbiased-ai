    "/monitoring/dashboard": {
      "get": {
        "tags": ["Monitoring"],
        "summary": "Get system dashboard metrics",
        "description": "Retrieve comprehensive system metrics for monitoring dashboard.",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["1h", "24h", "7d", "30d"],
              "default": "24h"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Dashboard metrics retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DashboardMetricsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/monitoring/alerts": {
      "get": {
        "tags": ["Monitoring"],
        "summary": "Get active alerts",
        "description": "Retrieve all active system alerts and notifications.",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "severity",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["low", "medium", "high", "critical", "all"],
              "default": "all"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alerts retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlertsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/scaling/status": {
      "get": {
        "tags": ["Scaling"],
        "summary": "Get scaling status",
        "description": "Check current system load and scaling recommendations.",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {
            "description": "Scaling status retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScalingStatusResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "BiasDetectionRequest": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": {
            "type": "string",
            "description": "Text content to analyze for bias",
            "maxLength": 10000
          },
          "type": {
            "type": "string",
            "enum": ["text", "email", "social_media", "news"],
            "default": "text",
            "description": "Type of content being analyzed"
          },
          "metadata": {
            "type": "object",
            "description": "Additional metadata about the content"
          }
        }
      },
      "BiasDetectionResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "detected": { "type": "boolean" },
              "biasInstances": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "phrase": { "type": "string" },
                    "biasType": {
                      "type": "string",
                      "enum": ["gender", "racial", "political", "age", "cultural", "socioeconomic"]
                    },
                    "severity": { "type": "string", "enum": ["low", "medium", "high"] },
                    "explanation": { "type": "string" },
                    "suggestion": { "type": "string" }
                  }
                }
              },
              "overallAssessment": { "type": "string" }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "processingTime": { "type": "number" },
              "model": { "type": "string" },
              "cached": { "type": "boolean" }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "status": { "type": "integer" },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "details": { "type": "object" }
            }
          }
        }
      },
      "RateLimitError": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string", "example": "RATE_LIMIT_EXCEEDED" },
              "message": { "type": "string" },
              "retryAfter": { "type": "number" }
            }
          }
        }
      }
    }
  }
}